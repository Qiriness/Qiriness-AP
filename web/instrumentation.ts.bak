import { loadRootEnv } from './lib/server/env';

export async function register() {
  if (process.env.NEXT_RUNTIME === 'nodejs') {
    console.log('[Instrumentation] Loading root env vars...');
    try {
      const envs = loadRootEnv();
      Object.assign(process.env, envs);
      console.log('[Instrumentation] Root env vars successfully assigned to process.env');
    } catch (e) {
      console.error('[Instrumentation] Error loading root env vars:', e);
    }
  }
}
