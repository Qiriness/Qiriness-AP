# Shopify
SHOPIFY_STORE_DOMAIN=your-dev-store.myshopify.com
SHOPIFY_CLIENT_ID=your_client_id
SHOPIFY_CLIENT_SECRET=your_client_secret

# Optional for Dev Dashboard apps: if blank, scripts request a 24-hour token
# using SHOPIFY_CLIENT_ID and SHOPIFY_CLIENT_SECRET.
SHOPIFY_ADMIN_API_ACCESS_TOKEN=
SHOPIFY_WEBHOOK_SECRET=your_shopify_webhook_secret
SHOPIFY_API_VERSION=unstable_or_supported_version
# Optional comma-separated Shopify metaobject definition types. If blank,
# the product sync targets Ingredients List and Product FAQ definitions by name.
SHOPIFY_METAOBJECT_TYPES=

# Nightly Shopify -> Supabase sync schedule for the deployment scheduler.
SYNC_CRON=0 2 * * *
SYNC_TIMEZONE=Europe/London

# Local compliance webhook harness inputs. Production runtimes should pass
# real HTTP headers directly to the webhook handler.
SHOPIFY_WEBHOOK_TOPIC=
SHOPIFY_WEBHOOK_SHOP_DOMAIN=
SHOPIFY_WEBHOOK_ID=
SHOPIFY_WEBHOOK_HMAC_SHA256=
SHOPIFY_WEBHOOK_API_VERSION=
SHOPIFY_WEBHOOK_TRIGGERED_AT=
SHOPIFY_WEBHOOK_EVENT_ID=

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key
SUPABASE_SECRET_KEY=your_supabase_secret_key
SUPABASE_DB_URL=postgresql://user:password@host:5432/database

# App
APP_ENV=development
LOG_LEVEL=info
